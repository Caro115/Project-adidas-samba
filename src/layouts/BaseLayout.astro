---
import "../styles/global.css";
const {
  title = "Adidas Samba | Monopolistic Competition",
  description = "Adidas Samba market analysis project with dedicated pages for value proposition, pricing, campaigns, and economic rationale."
} = Astro.props;

const normalizePath = (path) =>
  path.endsWith("/") && path !== "/" ? path.slice(0, -1) : path;

const currentPath = normalizePath(Astro.url.pathname);

const navLinks = [
  { href: "/", label: "Overview" },
  { href: "/value-proposition", label: "Value Proposition" },
  { href: "/market-pricing", label: "Pricing" },
  { href: "/campaigns", label: "Campaigns & Video" },
  { href: "/economic-analysis", label: "Economic Analysis" }
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description}
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.13),_transparent_50%)]"></div>
    <header class="sticky top-0 z-20 border-b border-white/10 bg-black/55 backdrop-blur-md">
      <div class="section-shell py-5 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <a href="/" class="text-white font-semibold tracking-[0.14em] uppercase text-xs">
          Adidas Samba Study
        </a>
        <nav aria-label="Primary">
          <ul class="flex flex-wrap gap-2">
            {navLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "nav-pill",
                    currentPath === normalizePath(item.href) && "border-white/30 bg-white/[0.12] text-white"
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main class="pb-24">
      <slot />
    </main>
    <footer class="section-shell border-t border-white/10 py-10 text-sm text-zinc-500">
      Adidas Samba project · Monopolistic competition case study
    </footer>
  </body>
</html>