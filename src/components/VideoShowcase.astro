<section class="section-shell py-16">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
    <div>
      <p class="section-kicker mb-3">Video section</p>
      <h2 class="section-title">Campaign mood videos</h2>
    </div>
    <p class="text-[#adbbc6] leading-relaxed max-w-xl">
      Two short clips that can be used as visual support for campaign storytelling
      and social-first presentation slides.
    </p>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <article class="glass-card p-5">
      <p class="text-sm uppercase tracking-[0.18em] text-[#adbbc6] mb-3">Video 01 · Main campaign clip</p>
      <video
        controls
        preload="metadata"
        poster="/images/Banner_Samba.jpg"
        class="w-full rounded-2xl border border-[#8a8fa3]/10 bg-[#374254]/30"
      >
        <source src="/images/Samba_video.mp4" type="video/mp4" />
      </video>
      <p class="mt-3 text-sm text-[#adbbc6]">
        Core product footage for launches, hero blocks, and short social edits.
      </p>
    </article>

    <article class="glass-card p-5">
      <p class="text-sm uppercase tracking-[0.18em] text-[#adbbc6] mb-3">Video 02 · Alternate playback</p>
      <video
        controls
        preload="metadata"
        poster="/images/Samba.jpg"
        class="w-full rounded-2xl border border-[#8a8fa3]/10 bg-[#374254]/30"
      >
        <source src="/images/Samba_video.mp4" type="video/mp4" />
        <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4" />
      </video>
      <p class="mt-3 text-sm text-[#adbbc6]">
        Backup player slot for loops, recaps, or versioned cuts of the same campaign.
      </p>
    </article>
  </div>
</section>
