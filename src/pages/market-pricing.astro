---
import BaseLayout from "../layouts/BaseLayout.astro";

const competitorData = [
  {
    brand: "Adidas Samba",
    priceRange: "$100–$130",
    brandValue: "95/100",
    differentiation: "Terrace heritage, gum sole DNA, minimalist profile",
    elasticity: "Low–Medium (relatively inelastic)",
    symbolicValue: "Very high",
    symbolicScore: 96
  },
  {
    brand: "Nike Cortez",
    priceRange: "$75–$110",
    brandValue: "90/100",
    differentiation: "Retro running identity and Americana styling",
    elasticity: "Medium",
    symbolicValue: "High",
    symbolicScore: 89
  },
  {
    brand: "Puma Palermo",
    priceRange: "$70–$110",
    brandValue: "78/100",
    differentiation: "Football-inspired silhouette with trend collabs",
    elasticity: "Medium–High",
    symbolicValue: "Medium–High",
    symbolicScore: 77
  },
  {
    brand: "Converse Chuck Taylor",
    priceRange: "$55–$90",
    brandValue: "88/100",
    differentiation: "Iconic canvas model and everyday universality",
    elasticity: "High",
    symbolicValue: "High",
    symbolicScore: 86
  },
  {
    brand: "New Balance 550",
    priceRange: "$110–$150",
    brandValue: "86/100",
    differentiation: "Retro basketball shape with premium lifestyle cues",
    elasticity: "Medium",
    symbolicValue: "Medium–High",
    symbolicScore: 84
  }
];
---

<BaseLayout
  title="Adidas Samba | Market Pricing and Competitor Comparison"
  description="Dedicated pricing analysis and competitor comparison for Adidas Samba in monopolistic competition."
>
  <section class="page-intro">
    <p class="section-kicker mb-3">Section 02</p>
    <h1 class="section-title mb-4">Market Pricing and Competitor Comparison</h1>
    <p class="muted-copy max-w-3xl">
      This page focuses on pricing power, substitute pressure, and direct benchmarking against major
      competitors in the retro lifestyle sneaker segment.
    </p>
  </section>

  <section class="section-shell pb-16 sm:pb-18">
    <div class="relative overflow-hidden rounded-2xl sm:rounded-[2rem] border border-[#8a8fa3]/12 bg-[#374254] p-6 sm:p-7 md:p-10 text-[#ececec] shadow-[0_30px_80px_-30px_rgba(0,0,0,0.4)]">
      <div class="absolute -right-8 sm:-right-12 -top-8 sm:-top-12 h-32 sm:h-44 w-32 sm:w-44 rounded-full bg-[#374254]/20 blur-3xl"></div>
      <div class="relative">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#adbbc6]">Price position</p>
        <h2 class="mt-3 text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight">$100–$130 USD</h2>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-[#adbbc6] sm:text-base">
          Samba sits in a defensible premium corridor: high enough to signal status and quality, but still within
          reach for broad lifestyle adoption. This range is sustained by differentiation rather than cost leadership.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <article class="rounded-2xl border border-[#8a8fa3]/15 bg-[#0e1424]/6 p-3">
            <p class="text-xs uppercase tracking-[0.16em] text-[#adbbc6]">Driver</p>
            <p class="mt-1 text-sm font-semibold text-[#ececec]">Brand equity</p>
          </article>
          <article class="rounded-2xl border border-[#8a8fa3]/15 bg-[#0e1424]/6 p-3">
            <p class="text-xs uppercase tracking-[0.16em] text-[#adbbc6]">Driver</p>
            <p class="mt-1 text-sm font-semibold text-[#ececec]">Trend amplification</p>
          </article>
          <article class="rounded-2xl border border-[#8a8fa3]/15 bg-[#0e1424]/6 p-3">
            <p class="text-xs uppercase tracking-[0.16em] text-[#adbbc6]">Constraint</p>
            <p class="mt-1 text-sm font-semibold text-[#ececec]">Substitute availability</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell pb-20">
    <div class="mb-8">
      <p class="section-kicker mb-3">Competitor comparison section</p>
      <h2 class="section-title mb-4">Adidas Samba vs Nike, Puma, Converse, and New Balance</h2>
      <p class="max-w-4xl leading-relaxed text-[#adbbc6]">
        The matrix compares price range, brand value, product differentiation, elasticity profile, and symbolic/social value.
      </p>
    </div>

    <div class="mb-6 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5">
        <p class="text-[11px] uppercase tracking-[0.18em] text-[#adbbc6]">Average competitor band</p>
        <p class="mt-2 text-2xl font-semibold text-[#ececec]">$55–$150</p>
      </article>
      <article class="glass-card p-5">
        <p class="text-[11px] uppercase tracking-[0.18em] text-[#adbbc6]">Samba brand value score</p>
        <p class="mt-2 text-2xl font-semibold text-[#ececec]">95 / 100</p>
      </article>
      <article class="glass-card p-5">
        <p class="text-[11px] uppercase tracking-[0.18em] text-[#adbbc6]">Pricing implication</p>
        <p class="mt-2 text-2xl font-semibold text-[#ececec]">High resilience</p>
      </article>
    </div>

    <div class="overflow-x-auto rounded-3xl border border-[#8a8fa3]/12 bg-[#0e1424]/6">
      <table class="w-full min-w-[920px]">
        <thead class="bg-[#374254]/20 text-left text-xs uppercase tracking-[0.18em] text-[#adbbc6]">
          <tr>
            <th class="px-5 py-4">Product</th>
            <th class="px-5 py-4">Price range</th>
            <th class="px-5 py-4">Brand value</th>
            <th class="px-5 py-4">Product differentiation</th>
            <th class="px-5 py-4">Elasticity of demand</th>
            <th class="px-5 py-4">Symbolic/social value</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#8a8fa3]/10 text-sm">
          {competitorData.map((item) => (
            <tr class:list={[item.brand === "Adidas Samba" && "bg-[#374254]/12"]}>
              <td class="px-5 py-4 font-semibold text-[#ececec]">{item.brand}</td>
              <td class="px-5 py-4 text-[#adbbc6]">{item.priceRange}</td>
              <td class="px-5 py-4 text-[#adbbc6]">{item.brandValue}</td>
              <td class="px-5 py-4 text-[#adbbc6]">{item.differentiation}</td>
              <td class="px-5 py-4 text-[#adbbc6]">{item.elasticity}</td>
              <td class="px-5 py-4">
                <div class="flex items-center gap-3">
                  <span class="text-[#adbbc6]">{item.symbolicValue}</span>
                  <div class="h-2 w-24 rounded-full bg-[#8a8fa3]/10">
                    <div
                      class="h-full rounded-full bg-gradient-to-r from-[#d8bfa0] to-[#8f6346]"
                      style={`width: ${item.symbolicScore}%`}
                    ></div>
                  </div>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>