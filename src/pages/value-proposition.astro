---
import BaseLayout from "../layouts/BaseLayout.astro";

const valueDrivers = [
  {
    title: "Cultural legacy",
    detail: "A long product history increases credibility and keeps the model relevant across generations."
  },
  {
    title: "Design recognizability",
    detail: "The low-profile silhouette and gum sole provide immediate brand identification."
  },
  {
    title: "Social signaling",
    detail: "Consumers use Samba to communicate taste, trend awareness, and belonging."
  },
  {
    title: "Lifestyle versatility",
    detail: "The model transitions across casual, smart-casual, and fashion-driven outfits."
  }
];

const prestigeIndicators = [
  { value: "High", label: "Perceived symbolic utility" },
  { value: "Global", label: "Cross-market desirability" },
  { value: "Low", label: "Substitution speed under loyal demand" }
];
---

<BaseLayout
  title="Adidas Samba | Value Proposition"
  description="Premium product differentiation and value proposition analysis for Adidas Samba."
>
  <section class="page-intro">
    <p class="section-kicker mb-3 text-[#adbbc6]">Section 01</p>
    <h1 class="section-title mb-4 text-[#ececec]">Value Proposition</h1>
    <p class="muted-copy max-w-3xl text-[#adbbc6]">
      This page isolates the premium product proposition behind Adidas Samba and explains why
      differentiation creates durable market preference in monopolistic competition.
    </p>
  </section>

  <section class="section-shell pb-16 sm:pb-18">
    <div class="glass-card p-6 sm:p-8 md:p-10">
      {/* Cambiado lg:items-start por lg:items-stretch para que ambas columnas midan lo mismo */}
      <div class="grid gap-8 md:gap-10 lg:grid-cols-2 lg:items-stretch">
        
        {/* Imagen - Orden 2 en mobile (abajo), orden 1 en lg (izquierda) */}
        {/* Agregada la clase h-full al contenedor y a la imagen */}
        <div class="order-2 lg:order-1 h-full">
          <img
            src="/images/Samba2.jpg"
            alt="Adidas Samba premium campaign visual"
            class="w-full h-full rounded-2xl sm:rounded-3xl border border-[#8a8fa3]/10 object-cover shadow-[0_30px_80px_-38px_rgba(0,0,0,0.9)]"
          />
        </div>

        {/* Bloque de texto - Orden 1 en mobile (arriba), orden 2 en lg (derecha) */}
        <div class="order-1 lg:order-2">
          <p class="section-kicker mb-3 text-[#adbbc6]">Premium product showcase</p>
          <h2 class="section-title mb-6 text-[#ececec]">Differentiation that consumers can feel and display</h2>
          <p class="mb-4 leading-relaxed text-[#adbbc6]">
            Samba competes with many substitutes, yet consumers repeatedly choose it because the value proposition
            combines function with identity. Buyers are not only purchasing footwear utility; they are purchasing
            heritage, aesthetic consistency, and social meaning.
          </p>
          <p class="mb-6 rounded-2xl border border-[#8a8fa3]/30 bg-[#374254]/10 px-4 py-3 text-sm text-[#adbbc6]">
            Emotional marketing hook: Adidas Samba is positioned as a timeless symbol rather than a seasonal product.
          </p>
          <div class="grid gap-3 sm:grid-cols-3">
            {prestigeIndicators.map((item) => (
              <article class="rounded-2xl border border-[#8a8fa3]/15 bg-[#0e1424]/65 p-4 sm:p-5">
                <p class="text-lg font-semibold text-[#ececec]">{item.value}</p>
                <p class="mt-2 text-xs uppercase tracking-[0.18em] text-[#adbbc6]">{item.label}</p>
              </article>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="section-shell pb-20">
    <div class="mb-6">
      <p class="section-kicker mb-3 text-[#adbbc6]">Product prestige indicators</p>
      <h2 class="section-title mb-4 text-[#ececec]">Core value drivers of Adidas Samba demand</h2>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {valueDrivers.map((driver) => (
        <article class="glass-card p-6 border border-[#8a8fa3]/20 bg-[#374254] transition duration-300 hover:-translate-y-0.5 hover:border-[#8a8fa3]/40">
          <h3 class="panel-title text-[#ececec]">{driver.title}</h3>
          <p class="text-sm leading-relaxed text-[#adbbc6]">{driver.detail}</p>
        </article>
      ))}
    </div>
    <div class="mt-7">
      <a href="/market-pricing" class="cta-secondary border border-[#8a8fa3] bg-[#374254] text-[#ececec] hover:text-[#adbbc6]">Continue to pricing and competitor analysis</a>
    </div>
  </section>
</BaseLayout>