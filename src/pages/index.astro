---
import BaseLayout from "../layouts/BaseLayout.astro";

const prestigeSignals = [
  { value: "70+ years", label: "Heritage credibility" },
  { value: "$100–$130", label: "Premium price corridor" },
  { value: "Global icon", label: "Symbolic social status" },
  { value: "A+ framing", label: "Professor-ready presentation" }
];

const sectionPages = [
  {
    href: "/value-proposition",
    title: "Value Proposition",
    detail: "Premium product storytelling, differentiation logic, and prestige indicators."
  },
  {
    href: "/market-pricing",
    title: "Pricing & Competitors",
    detail: "Price ranges, brand-value benchmarking, and structured competitor comparison."
  },
  {
    href: "/campaigns",
    title: "Campaigns & Video",
    detail: "Influencer strategy, social proof, trend simulation, and embedded media."
  },
  {
    href: "/economic-analysis",
    title: "Economic Analysis",
    detail: "Demand elasticity, monopolistic competition visuals, and final academic closure."
  }
];
---

<BaseLayout
  title="Adidas Samba | Premium Monopolistic Competition Project"
  description="Premium overview page for a multi-page university project analyzing Adidas Samba in monopolistic competition."
>
  <section class="section-shell pb-16 pt-12 sm:pb-20 sm:pt-14 md:pb-24 md:pt-24">
    <div class="grid items-center gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
      <div class="space-y-6 sm:space-y-7">
        <p class="section-kicker">University of Colima Microeconomics.</p>
        <h1 class="text-4xl font-semibold leading-[0.92] tracking-tight text-[#ececec] sm:text-5xl md:text-6xl lg:text-7xl">
          Adidas Samba:
          <br />
          Premium Identity in
          <br />
          Monopolistic Competition
        </h1>
        <p class="max-w-2xl text-base leading-relaxed text-[#adbbc6] sm:text-lg md:text-xl">
          This project explains how product differentiation, brand loyalty, and cultural positioning
          create pricing power despite many close substitutes.
        </p>
        <p class="max-w-xl rounded-2xl border border-[#8a8fa3]/30 bg-[#374254]/10 px-4 py-3 text-sm text-[#adbbc6]">
          Core thesis: consumers purchase symbolic value, not only utility.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/economic-analysis" class="cta-primary text-center">Open data visualization</a>
          <a href="/campaigns" class="cta-secondary text-center">Open campaign strategy</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {prestigeSignals.map((signal) => (
            <article class="glass-card p-4 transition duration-300 hover:-translate-y-0.5 hover:border-[#8a8fa3]/40">
              <p class="text-xl font-semibold text-[#ececec]">{signal.value}</p>
              <p class="mt-1 text-sm text-[#adbbc6]">{signal.label}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-10 -z-10 rounded-[3rem] bg-[radial-gradient(circle_at_30%_20%,rgba(212,188,158,0.35),transparent_62%)] blur-2xl"></div>
          <article class="glass-card p-4 sm:p-5">
          <img
            src="/images/Samba.jpg"
            alt="Adidas Samba premium product view"
            class="h-full w-full rounded-[1.8rem] border border-[#8a8fa3]/12 object-cover shadow-[0_40px_120px_-45px_rgba(0,0,0,0.95)]"
          />
          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-[#8a8fa3]/12 bg-[#374254]/30 p-3">
              <p class="text-[10px] uppercase tracking-[0.18em] text-[#adbbc6]">Positioning</p>
              <p class="mt-1 text-sm font-medium text-[#ececec]">Premium lifestyle classic</p>
            </div>
            <div class="rounded-2xl border border-[#8a8fa3]/12 bg-[#374254]/30 p-3">
              <p class="text-[10px] uppercase tracking-[0.18em] text-[#adbbc6]">Market structure</p>
              <p class="mt-1 text-sm font-medium text-[#ececec]">Monopolistic competition</p>
            </div>
            <div class="rounded-2xl border border-[#8a8fa3]/55 bg-[#374254]/15 p-3">
              <p class="text-[10px] uppercase tracking-[0.18em] text-[#adbbc6]">Economic signal</p>
              <p class="mt-1 text-sm font-medium text-[#ececec]">Relative price resilience</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section-shell pb-20">
    <div class="mb-7">
      <p class="section-kicker mb-3">Project architecture</p>
      <h2 class="section-title mb-4">Each section is now split by dedicated page</h2>
      <p class="max-w-3xl leading-relaxed text-[#adbbc6]">
        Use the cards below to navigate the full analysis. Each topic has its own route for cleaner
        professor evaluation, clearer visual hierarchy, and stronger academic organization.
      </p>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {sectionPages.map((page) => (
        <a href={page.href} class="panel-link">
          <h3 class="panel-title">{page.title}</h3>
          <p class="text-sm leading-relaxed text-[#adbbc6]">{page.detail}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>