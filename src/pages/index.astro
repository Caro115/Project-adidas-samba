---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ValueProposition from "../components/ValueProposition.astro";
import PriceTag from "../components/PriceTag.astro";
import AdBannerInstagram from "../components/AdBannerInstagram.astro";
import AdBannerTikTok from "../components/AdBannerTikTok.astro";
import EconomicJustification from "../components/EconomicJustification.astro";
---

<BaseLayout>
  <Hero />
  <ValueProposition />
  <PriceTag />
  <section class="section-shell py-20">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
      <div>
        <p class="section-kicker mb-3">Campañas digitales</p>
        <h2 class="section-title">
          Publicidad simulada
        </h2>
      </div>
      <p class="text-zinc-400 leading-relaxed max-w-xl">
        Dos formatos de comunicación enfocados en awareness y tendencia:
        uno para estética editorial en Instagram y otro para tracción viral
        en TikTok.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <AdBannerInstagram />
      <AdBannerTikTok />
    </div>
  </section>

  <EconomicJustification />
</BaseLayout>